AAQ,WAAW,KAAK;;;cAAxBC,gBAAAC,gBAAA,QAAA,QAAQ,WAAW,KAAK,IAAG,KAC9B,CAAA;AAAA,cAAAC,YAAc,cAAR,GAAC;AAAA,YAAA;AAAA;;;;;QAEE,IAAI,QAAA,QAAQ,aAAa;AAAA,QAAI,OAAM;AAAA,MAAA;yBAA9C,CAGW,GAAAJ,QAAAC,UAAA,aAAA;;qCAFN,QAAA,QAAQ,aAAa,KAAK;;;cAA1BC,gBAAAC,gBAAA,QAAA,QAAQ,aAAa,KAAK,IAAG,KAChC,CAAA;AAAA,cAAAC,YAAc,cAAR,GAAC;AAAA,YAAA;AAAA;;;;;;;;;;;;;;;;;;ACjBrB,YAAQ;AAAA,MACN,OAAO,YAAY,IAAI;AAAA,MACvB,MAAM;AAAA,QACJ;AAAA,UACE,MAAM;AAAA,UACN,SAAS,YAAY,IAAI;AAAA,QAAA;AAAA,MAC3B;AAAA,IACF,CACD;;;;;;;;;AAYM,YAAA,OAAAR,eAAAC,WAAA,EAAA,OAAM,8BAA0B,MAAA,CAAA,CAAA,GAAA;;QACvB,OAAOS,MAAA,WAAA,EAAY;AAAA,MAAA;;;QAGP,SAASA,MAAA,WAAA,EAAY;AAAA,MAAA;;QACpB,SAASA,MAAA,WAAA,EAAY;AAAA,MAAA;;QAClB,MAAMA,MAAA,WAAA,EAAY,MAAK,CAAA;AAAA,MAAA;;QAC3B,QAAQA,MAAA,WAAA,EAAY;AAAA,QAAa,OAAOA,MAAA,WAAA,EAAY;AAAA,MAAA;;QAChD,SAASA,MAAA,WAAA,EAAY;AAAA,MAAA;;;QAI9C,YAAYA,MAAA,WAAA,EAAY,OAAO;AAAA,QAC/B,UAAUA,MAAA,WAAA,EAAY,OAAO;AAAA,QAC7B,OAAOA,MAAA,WAAA,EAAY,OAAO;AAAA,MAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderStyle","_ssrInterpolate","_push","_parent","_createTextVNode","_toDisplayString","_createVNode","_ssrRenderList","_unref"],"sources":["../../../../components/sections/BlogPageHeroSection.vue","../../../../components/sections/BlogPageIntroSection.vue","../../../../components/sections/BlogPageFeaturedSection.vue","../../../../components/sections/BlogPageListSection.vue","../../../../components/sections/BlogPageFinalCtaSection.vue","../../../../pages/blog/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\ndefineProps<{\n  content: {\n    badge: string\n    titleLead: string\n    titleAccent: string\n    titleEnd: string\n    copy: string\n    primaryCta: { label: string; to: string }\n    secondaryCta: { label: string; to: string }\n    image: string\n    backgroundImage: string\n  }\n}>()\n</script>\n\n<template>\n  <section class=\"relative overflow-hidden pt-32 sm:pt-36 lg:min-h-screen lg:pt-40\">\n    <div class=\"absolute inset-0 overflow-hidden\">\n      <div\n        data-blog-hero-bg\n        class=\"absolute inset-0 scale-110 bg-cover bg-center opacity-30\"\n        :style=\"{ backgroundImage: `url(${content.backgroundImage})` }\"\n      />\n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(201,167,106,0.22),transparent_24%),linear-gradient(180deg,rgba(8,8,8,0.2),rgba(8,8,8,0.9)_68%,rgba(8,8,8,1))]\" />\n    </div>\n\n    <div class=\"container-shell relative z-10 pb-20 sm:pb-24 lg:pb-28\">\n      <div class=\"grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center\">\n        <div data-blog-hero-content class=\"max-w-4xl\">\n          <span class=\"section-label\">{{ content.badge }}</span>\n\n          <h1 class=\"section-title mt-8 max-w-5xl text-5xl sm:text-6xl lg:text-[5.45rem]\">\n            {{ content.titleLead }}<br>\n            <em class=\"font-normal text-[var(--accent)]\">{{ content.titleAccent }}</em><br>\n            {{ content.titleEnd }}\n          </h1>\n\n          <p class=\"mt-8 max-w-2xl text-lg leading-8 text-[var(--muted)] sm:text-xl sm:leading-9\">\n            {{ content.copy }}\n          </p>\n\n          <div class=\"mt-10 flex flex-col gap-4 sm:flex-row sm:items-center\">\n            <NuxtLink :to=\"content.primaryCta.to\" class=\"gold-button\">\n              {{ content.primaryCta.label }}\n              <span>→</span>\n            </NuxtLink>\n            <NuxtLink :to=\"content.secondaryCta.to\" class=\"ghost-button\">\n              {{ content.secondaryCta.label }}\n              <span>→</span>\n            </NuxtLink>\n          </div>\n        </div>\n\n        <div data-blog-hero-image class=\"relative mx-auto w-full max-w-[35rem] lg:mx-0\">\n          <div class=\"absolute -left-3 top-14 h-2.5 w-2.5 rounded-full bg-[var(--accent)]\" />\n          <div class=\"absolute left-9 top-8 h-14 w-14 rounded-full border border-[rgba(213,182,128,0.35)]\" />\n          <div class=\"absolute -right-6 top-6 h-60 w-60 rounded-full border border-[rgba(255,255,255,0.34)] sm:h-72 sm:w-72\" />\n          <div class=\"absolute right-12 top-16 h-40 w-40 rounded-full border border-[rgba(201,167,106,0.28)] sm:h-52 sm:w-52\" />\n\n          <div class=\"panel relative overflow-hidden p-4 sm:p-5\">\n            <div class=\"absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),transparent_24%)]\" />\n            <img :src=\"content.image\" alt=\"Blog\" class=\"h-[500px] w-full object-cover object-center sm:h-[620px]\" />\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[rgba(8,8,8,0.48)] via-transparent to-transparent\" />\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\ndefineProps<{\n  content: {\n    label: string\n    title: string\n    copy: string\n  }\n}>()\n</script>\n\n<template>\n  <section class=\"relative py-24 sm:py-28\">\n    <div class=\"container-shell\">\n      <div data-reveal class=\"mx-auto max-w-4xl text-center\">\n        <span class=\"section-label justify-center\">{{ content.label }}</span>\n        <h2 class=\"section-title mt-8\">{{ content.title }}</h2>\n        <p class=\"section-copy mx-auto mt-8 text-center\">\n          {{ content.copy }}\n        </p>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\ndefineProps<{\n  post: {\n    slug: string\n    category: string\n    title: string\n    excerpt: string\n    readingTime: string\n    image: string\n  }\n}>()\n</script>\n\n<template>\n  <section class=\"relative overflow-hidden py-8 sm:py-10\">\n    <div class=\"container-shell\">\n      <div data-reveal class=\"panel relative overflow-hidden\">\n        <div\n          data-blog-featured-bg\n          class=\"absolute inset-y-0 right-0 hidden w-1/2 scale-110 bg-cover bg-center opacity-30 lg:block\"\n          :style=\"{ backgroundImage: `url(${post.image})` }\"\n        />\n        <div class=\"absolute inset-0 bg-[linear-gradient(135deg,rgba(201,167,106,0.12),transparent_40%),linear-gradient(180deg,rgba(255,255,255,0.02),transparent_35%)]\" />\n\n        <div class=\"relative grid gap-10 p-8 sm:p-10 lg:grid-cols-[1.1fr_0.9fr] lg:p-12 xl:p-14\">\n          <div class=\"max-w-2xl\">\n            <span class=\"section-label\">Empfohlener Beitrag</span>\n            <p class=\"mt-8 tiny-kicker text-[var(--accent)]\">{{ post.category }}</p>\n            <h2 class=\"display-face mt-5 text-3xl leading-tight text-[var(--text)] sm:text-4xl lg:text-5xl\">\n              {{ post.title }}\n            </h2>\n            <p class=\"mt-6 max-w-xl text-base leading-8 text-[var(--muted)] sm:text-lg\">\n              {{ post.excerpt }}\n            </p>\n            <div class=\"mt-8 flex flex-wrap items-center gap-4 text-[11px] uppercase tracking-[0.28em] text-[rgba(242,236,226,0.54)]\">\n              <span>{{ post.readingTime }}</span>\n              <span class=\"h-px w-8 bg-[rgba(201,167,106,0.25)]\" />\n              <span>SeitenArchitekt</span>\n            </div>\n            <NuxtLink :to=\"`/blog/${post.slug}`\" class=\"gold-button mt-10\">\n              Beitrag öffnen\n              <span>→</span>\n            </NuxtLink>\n          </div>\n\n          <div class=\"relative hidden min-h-[18rem] lg:block\">\n            <div class=\"absolute right-10 top-8 h-20 w-20 rounded-full border border-[rgba(201,167,106,0.25)]\" />\n            <div class=\"absolute right-20 top-20 h-3 w-3 rounded-full bg-[var(--accent)]\" />\n            <div class=\"absolute inset-x-10 bottom-0 top-12 overflow-hidden rounded-[1.75rem] border border-[rgba(255,255,255,0.08)]\">\n              <img :src=\"post.image\" alt=\"Featured\" class=\"h-full w-full object-cover object-center opacity-80\" />\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[rgba(8,8,8,0.8)] via-[rgba(8,8,8,0.18)] to-transparent\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\ndefineProps<{\n  header: {\n    label: string\n    title: string\n  }\n  posts: Array<{\n    slug: string\n    category: string\n    title: string\n    excerpt: string\n    readingTime: string\n    image: string\n  }>\n}>()\n</script>\n\n<template>\n  <section class=\"py-24 sm:py-28\">\n    <div class=\"container-shell\">\n      <div data-reveal class=\"text-center\">\n        <span class=\"section-label justify-center\">{{ header.label }}</span>\n        <h2 class=\"section-title mt-8\">{{ header.title }}</h2>\n      </div>\n\n      <div class=\"mt-14 grid gap-6 lg:grid-cols-3\">\n        <article v-for=\"post in posts\" :key=\"post.slug\" data-reveal class=\"lux-card group relative overflow-hidden p-[1px]\">\n          <div class=\"absolute inset-0 bg-[linear-gradient(135deg,rgba(201,167,106,0.22),transparent_36%,transparent_64%,rgba(255,255,255,0.06))] opacity-70 transition duration-300 group-hover:opacity-100\" />\n          <div class=\"relative h-full bg-[linear-gradient(180deg,rgba(14,14,14,0.92),rgba(9,9,9,0.88))] p-5 sm:p-6\">\n            <div class=\"overflow-hidden rounded-[1.5rem] border border-[rgba(255,255,255,0.08)]\">\n              <img :src=\"post.image\" :alt=\"post.title\" class=\"h-56 w-full object-cover object-center transition duration-500 group-hover:scale-[1.04]\" />\n            </div>\n\n            <div class=\"mt-6 flex items-center justify-between gap-4 text-[10px] uppercase tracking-[0.28em] text-[rgba(242,236,226,0.52)]\">\n              <span class=\"text-[var(--accent)]\">{{ post.category }}</span>\n              <span>{{ post.readingTime }}</span>\n            </div>\n\n            <h3 class=\"display-face mt-5 text-2xl leading-tight text-[var(--text)] sm:text-[2rem]\">\n              {{ post.title }}\n            </h3>\n\n            <p class=\"mt-4 text-base leading-8 text-[var(--muted)]\">\n              {{ post.excerpt }}\n            </p>\n\n            <NuxtLink :to=\"`/blog/${post.slug}`\" class=\"ghost-button mt-7\">\n              Artikel lesen\n              <span>→</span>\n            </NuxtLink>\n          </div>\n        </article>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\ndefineProps<{\n  content: {\n    title: string\n    copy: string\n    primaryCta: { label: string; to: string }\n    secondaryCta: { label: string; to: string }\n  }\n}>()\n</script>\n\n<template>\n  <section class=\"py-24 sm:py-28\">\n    <div class=\"container-shell\">\n      <div data-reveal class=\"panel relative overflow-hidden px-8 py-12 sm:px-10 sm:py-14 lg:px-14 lg:py-16\">\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(201,167,106,0.14),transparent_34%),linear-gradient(135deg,rgba(255,255,255,0.02),transparent_52%)]\" />\n        <div class=\"relative flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between\">\n          <div class=\"max-w-3xl\">\n            <span class=\"section-label\">Nächster Schritt</span>\n            <h2 class=\"section-title mt-8\">{{ content.title }}</h2>\n            <p class=\"section-copy mt-8\">{{ content.copy }}</p>\n          </div>\n\n          <div class=\"flex flex-col gap-4 sm:flex-row sm:items-center lg:flex-col lg:items-start xl:flex-row xl:items-center\">\n            <NuxtLink :to=\"content.primaryCta.to\" class=\"gold-button\">\n              {{ content.primaryCta.label }}\n              <span>→</span>\n            </NuxtLink>\n            <NuxtLink :to=\"content.secondaryCta.to\" class=\"ghost-button\">\n              {{ content.secondaryCta.label }}\n              <span>→</span>\n            </NuxtLink>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nimport { blogContent } from '~/data/blogContent'\nimport { homeContent } from '~/data/homeContent'\n\nconst { initAnimations, destroyAnimations } = useBlogGsap()\n\ndefinePageMeta({\n  pageTransition: {\n    name: 'page-fade',\n    mode: 'out-in'\n  }\n})\n\nuseHead({\n  title: blogContent.seo.title,\n  meta: [\n    {\n      name: 'description',\n      content: blogContent.seo.description\n    }\n  ]\n})\n\nonMounted(() => {\n  initAnimations()\n})\n\nonBeforeUnmount(() => {\n  destroyAnimations()\n})\n</script>\n\n<template>\n  <div class=\"relative overflow-hidden\">\n    <AppHeader :links=\"homeContent.navLinks\" />\n\n    <main>\n      <BlogPageHeroSection :content=\"blogContent.hero\" />\n      <BlogPageIntroSection :content=\"blogContent.intro\" />\n      <BlogPageFeaturedSection :post=\"blogContent.posts[0]\" />\n      <BlogPageListSection :header=\"blogContent.listHeader\" :posts=\"blogContent.posts\" />\n      <BlogPageFinalCtaSection :content=\"blogContent.finalCta\" />\n    </main>\n\n    <AppFooter\n      :navigation=\"homeContent.footer.navigation\"\n      :services=\"homeContent.footer.services\"\n      :legal=\"homeContent.footer.legal\"\n    />\n  </div>\n</template>\n"],"version":3}